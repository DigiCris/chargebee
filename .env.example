# Copy this file to .env and fill it.
# Use the FULL ACCESS key, not the publishable key.
CHARGEBEE_SITE="comunyt-test"
CHARGEBEE_API_KEY="test_G9...FULL_ACCESS_KEY_HERE"

# Editable test names/ids. Keep ids simple: lowercase, numbers, hyphens/underscores.
MERCHANT_ID="merchant-demo-001"
ITEM_ID="comunyt-demo-plan"
ITEM_NAME="comunyt Demo Subscription"
ITEM_PRICE_ID="comunyt-demo-plan-usd-monthly"
ITEM_PRICE_NAME="comunyt Demo Plan USD Monthly"
CUSTOMER_ID="comunyt-user-demo-001"
CUSTOMER_EMAIL="demo-user@comunyt.test"
CUSTOMER_FIRST_NAME="Demo"
CUSTOMER_LAST_NAME="User"

# Chargebee amounts are minor units: 1000 = USD 10.00
PRICE_CENTS="1000"
CURRENCY="USD"
PERIOD="1"
PERIOD_UNIT="month"

# Filled after subscription/invoice creation if needed
SUBSCRIPTION_ID=""
INVOICE_ID=""
RECORD_PAYMENT_AMOUNT_CENTS="1000"
